{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["public/**"]
      }
    }
  ],
  "routes": [
  { "src": "/(.*\\.(js|css|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf))", "dest": "/public/$1" },
  { "src": "/(.*)", "dest": "backend/server.js" }
]
  "crons": [
    {
      "path": "/api/cron/reminder",
      "schedule": "0 0 * * *"
    }
  ]
}
