{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/webhook(.*)", "dest": "backend/server.js" },
    { "src": "/api/(.*)", "dest": "backend/server.js" },
    { "src": "/assets/(.*)", "dest": "/public/assets/$1" },
    { "src": "/admin", "dest": "/public/admin.html" },
    { "src": "/laporan", "dest": "/public/laporan.html" },
    { "src": "/alert", "dest": "/public/alert.html" },
    { "src": "/", "dest": "/public/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/reminder",
      "schedule": "0 0 * * *"
    }
  ]
}
